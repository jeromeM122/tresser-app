      "url": "/diagnostic?source=shortcut",
      "icons": [{ "src": "/icons/shortcut-diagnostic.png", "sizes": "96x96" }]
    }
  ],

  "prefer_related_applications": false,

  "related_applications": [
    {
      "platform": "webapp",
      "url": "https://tresser.fr/manifest.json"
